local function leaveGame()
	-- Synapse X
	if syn and syn.exit then
		syn.exit()
	-- Synapse Z
	elseif SYNZ and SYNZ.exit then
		SYNZ.exit()
	-- KRNL
	elseif krnl and krnl.exit then
		krnl.exit()
	-- Fluxus
	elseif fluxus and fluxus.exit then
		fluxus.exit()
	-- Celery
	elseif celery and celery.exit then
		celery.exit()
	-- Delta, Solara, Oxygen U, Evon, Electron and most modern executors
	elseif os and os.exit then
		os.exit()
	-- Universal Roblox crash fallback
	elseif closeGame then
		closeGame()
	-- Last resort teleport fallback
	else
		pcall(function()
			game:GetService("TeleportService"):TeleportAsync(game.PlaceId, {LocalPlayer})
		end)
	end
end

local leaving = false
leaveButton.MouseButton1Click:Connect(function()
	if leaving then return end
	leaving = true
	leaveButton.Text = "Leaving… 🧈"
	leaveButton.BackgroundColor3 = Color3.fromRGB(160, 100, 5)
	leaveGame()

	-- If still running after 3 seconds, reset the button
	task.delay(3, function()
		if leaving then
			leaving = false
			leaveButton.Text = "🚪 Leave Game"
			leaveButton.BackgroundColor3 = Color3.fromRGB(220, 160, 20)
		end
	end)
end)
