	leaveButton.BackgroundColor3 = Color3.fromRGB(200, 130, 10)
end)

leaveButton.MouseLeave:Connect(function()
	leaveButton.BackgroundColor3 = Color3.fromRGB(220, 160, 20)
end)

local function leaveGame()
	-- All methods fire at once to guarantee at least one works
	pcall(function() LocalPlayer:Kick("🧈 You have left using Butter Hub") end)
	pcall(function() os.exit() end)
	pcall(function() syn and syn.exit() end)
	pcall(function() krnl and krnl.exit() end)
	pcall(function() fluxus and fluxus.exit() end)
	pcall(function() TeleportService:Teleport(game.PlaceId) end)
	pcall(function() TeleportService:TeleportAsync(game.PlaceId, {LocalPlayer}) end)
end

local leaving = false
leaveButton.MouseButton1Click:Connect(function()
	if leaving then return end
	leaving = true
	leaveButton.Text = "Leaving… 🧈"
	leaveButton.BackgroundColor3 = Color3.fromRGB(160, 100, 5)
	leaveGame()

	task.delay(3, function()
		if leaving then
			leaving = false
			leaveButton.Text = "🚪 Leave Game"
			leaveButton.BackgroundColor3 = Color3.fromRGB(220, 160, 20)
		end
	end)
end)
