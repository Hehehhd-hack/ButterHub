butterButton.Text = "🧈"
butterButton.TextSize = 30
butterButton.BackgroundColor3 = Color3.new(1, 1, 1)
butterButton.BorderSizePixel = 0
butterButton.Parent = screenGui

local butterCorner = Instance.new("UICorner")
butterCorner.CornerRadius = UDim.new(0, 10)
butterCorner.Parent = butterButton

-- Powers container - SMALLER & COMPACT
local powersFrame = Instance.new("Frame")
powersFrame.Size = UDim2.new(0, 180, 0, 320)
powersFrame.Position = UDim2.new(0, 70, 0, 10) -- Next to butter button
powersFrame.BackgroundColor3 = Color3.fromRGB(255, 248, 220)
powersFrame.BorderSizePixel = 0
powersFrame.Visible = false
powersFrame.Active = true
powersFrame.Draggable = true
powersFrame.Parent = screenGui

local frameCorner = Instance.new("UICorner")
frameCorner.CornerRadius = UDim.new(0, 12)
frameCorner.Parent = powersFrame

-- Add title
local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, 0, 0, 35)
title.Position = UDim2.new(0, 0, 0, 0)
title.Text = "🧈 BUTTER POWERS 🧈"
