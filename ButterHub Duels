				local percentage = math.clamp((mousePos - sliderPos) / sliderSize, 0, 1)
				
				normalSpeed = math.floor(10 + (percentage * 40))
				normalSliderFill.Size = UDim2.new(percentage, 0, 1, 0)
				normalSpeedLabel.Text = "Normal Speed: " .. normalSpeed
			end
			
			if draggingStealing then
				local mousePos = UserInputService:GetMouseLocation().X
				local sliderPos = stealingSliderBg.AbsolutePosition.X
				local sliderSize = stealingSliderBg.AbsoluteSize.X
				local percentage = math.clamp((mousePos - sliderPos) / sliderSize, 0, 1)
				
				stealingSpeed = math.floor(5 + (percentage * 30))
				stealingSliderFill.Size = UDim2.new(percentage, 0, 1, 0)
				stealingSpeedLabel.Text = "Stealing Speed: " .. stealingSpeed
			end
		end
	end)

	-- Monitor brainrot and adjust speed
	task.spawn(function()
		while task.wait(0.5) do
			pcall(function()
				if not speedBoostActive and character and humanoid then
					local hasBrainrot = false
					
					for _, tool in pairs(character:GetChildren()) do
						if tool:IsA("Tool") and (tool.Name:lower():find("brainrot") or tool.Name:lower():find("steal")) then
							hasBrainrot = true
							break
						end
					end
					
					if not hasBrainrot then
						for _, tool in pairs(backpack:GetChildren()) do
							if tool:IsA("Tool") and (tool.Name:lower():find("brainrot") or tool.Name:lower():find("steal")) then
								hasBrainrot = true
								break
							end
						end
					end
					
					if hasBrainrot then
						humanoid.WalkSpeed = stealingSpeed
					else
						humanoid.WalkSpeed = normalSpeed
					end
				end
			end)
		end
	end)
end

