-- FLING POWER (Starts OFF)
local flingActive = false
local flingButton = createPowerButton("FLING", "🌪️", 220)

flingButton.MouseButton1Click:Connect(function()
	flingActive = not flingActive
	
	if flingActive then
		flingButton.BackgroundColor3 = Color3.fromRGB(255, 100, 255)
		flingButton.Text = "🌪️ FLING: ON"
	else
		flingButton.BackgroundColor3 = Color3.fromRGB(255, 200, 87)
		flingButton.Text = "🌪️ FLING"
	end
end)

-- Fling detection
humanoidRootPart.Touched:Connect(function(hit)
	if flingActive and hit.Parent:FindFirstChild("Humanoid") then
		local otherPlayer = game.Players:GetPlayerFromCharacter(hit.Parent)
		if otherPlayer and otherPlayer ~= player then
			local otherRoot = hit.Parent:FindFirstChild("HumanoidRootPart")
			if otherRoot then
				local direction = (otherRoot.Position - humanoidRootPart.Position).Unit
				local bodyVelocity = Instance.new("BodyVelocity")
				bodyVelocity.Velocity = direction * 100 + Vector3.new(0, 50, 0)
				bodyVelocity.MaxForce = Vector3.new(100000, 100000, 100000)
				bodyVelocity.Parent = otherRoot
				
				game:GetService("Debris"):AddItem(bodyVelocity, 0.5)
			end
		end
	end
end)

-- REDUCE LAG POWER
local lagReductionActive = false
local lagButton = createPowerButton("REDUCE LAG", "🔧", 265)

lagButton.MouseButton1Click:Connect(function()
	lagReductionActive = not lagReductionActive
	
	if lagReductionActive then
		-- Lower graphics quality
		local lighting = game:GetService("Lighting")
		local settings = UserSettings():GetService("UserGameSettings")
		
		-- Reduce quality settings
		settings.SavedQualityLevel = Enum.SavedQualitySetting.QualityLevel1
		
		-- Disable expensive effects
		for _, effect in pairs(lighting:GetChildren()) do
			if effect:IsA("PostEffect") or effect:IsA("BloomEffect") or effect:IsA("BlurEffect") or 
			   effect:IsA("ColorCorrectionEffect") or effect:IsA("SunRaysEffect") or effect:IsA("DepthOfFieldEffect") then
				effect.Enabled = false
			end
		end
		
		-- Reduce particle effects
		for _, obj in pairs(workspace:GetDescendants()) do
			if obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Smoke") or obj:IsA("Fire") or obj:IsA("Sparkles") then
				obj.Enabled = false
			end
		end
		
		lagButton.BackgroundColor3 = Color3.fromRGB(100, 255, 100)
		lagButton.Text = "🔧 LAG REDUCED"
	else
		-- Restore graphics
		local settings = UserSettings():GetService("UserGameSettings")
		settings.SavedQualityLevel = Enum.SavedQualitySetting.Automatic
		
		lagButton.BackgroundColor3 = Color3.fromRGB(255, 200, 87)
		lagButton.Text = "🔧 REDUCE LAG"
	end
end)
]]

loadstring(code)()
