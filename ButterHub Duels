-- Helper function to create power buttons
local function createPowerButton(name, emoji, position, callback)
	local button = Instance.new("TextButton")
	button.Size = UDim2.new(0.9, 0, 0, 50)
	button.Position = UDim2.new(0.05, 0, 0, position)
	button.Text = emoji .. " " .. name
	button.TextSize = 14
	button.Font = Enum.Font.GothamBold
	button.TextColor3 = Color3.new(1, 1, 1)
	button.BackgroundColor3 = Color3.fromRGB(255, 200, 87) -- Butter yellow
	button.BorderSizePixel = 0
	button.Parent = powersFrame
	
	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 10)
	corner.Parent = button
	
	button.MouseButton1Click:Connect(callback)
	
	return button
end

-- AUTO GRAB POWER (Always on by default)
local autoGrabActive = true
local autoGrabButton = createPowerButton("AUTO GRAB: ON", "🪙", 50, function()
	autoGrabActive = not autoGrabActive
	
	if autoGrabActive then
		autoGrabButton.BackgroundColor3 = Color3.fromRGB(100, 255, 100) -- Green when active
		autoGrabButton.Text = "🪙 AUTO GRAB: ON"
	else
		autoGrabButton.BackgroundColor3 = Color3.fromRGB(255, 200, 87) -- Back to butter yellow
		autoGrabButton.Text = "🪙 AUTO GRAB: OFF"
	end
end)

-- Set initial color to green since it's on by default
autoGrabButton.BackgroundColor3 = Color3.fromRGB(100, 255, 100)

-- Auto grab functionality
local function autoGrabCoins()
	while wait(0.1) do
		if autoGrabActive then
			for _, obj in pairs(workspace:GetDescendants()) do
				if obj:IsA("ProximityPrompt") then
					-- Check if the prompt is within range
					local promptParent = obj.Parent
					if promptParent and promptParent:IsA("BasePart") then
						local distance = (promptParent.Position - humanoidRootPart.Position).Magnitude
						if distance <= obj.MaxActivationDistance then
							-- Fire the proximity prompt
							fireproximityprompt(obj)
						end
					end
				end
			end
		end
	end
end

-- Start auto grab in a separate thread
coroutine.wrap(autoGrabCoins)()

-- TELEPORT POWER
local teleportCooldown = false
createPowerButton("TELEPORT", "⚡", 110, function()
	if teleportCooldown then return end
	teleportCooldown = true
	
	-- Equip FlyingCarpet
	local carpet = backpack:FindFirstChild("FlyingCarpet") or character:FindFirstChild("FlyingCarpet")
	if carpet and carpet.Parent == backpack then
		humanoid:EquipTool(carpet)
	end
	
	wait(0.1)
	
	local lookDirection = humanoidRootPart.CFrame.LookVector
	local newPosition = humanoidRootPart.Position + (lookDirection * 50)
	humanoidRootPart.CFrame = CFrame.new(newPosition, newPosition + lookDirection)
	
	-- Effect
	local effect = Instance.new("Part")
	effect.Shape = Enum.PartType.Ball
	effect.Material = Enum.Material.Neon
	effect.Color = Color3.fromRGB(255, 200, 87)
	effect.Size = Vector3.new(3, 3, 3)
	effect.Anchored = true
	effect.CanCollide = false
	effect.CFrame = CFrame.new(humanoidRootPart.Position)
	effect.Parent = workspace
	
	game:GetService("TweenService"):Create(effect, TweenInfo.new(0.5), {
		Transparency = 1,
		Size = Vector3.new(8, 8, 8)
	}):Play()
	
	game:GetService("Debris"):AddItem(effect, 0.5)
	
	wait(2)
	teleportCooldown = false
end)

-- LOCK ON POWER
local lockOnCooldown = false
createPowerButton("LOCK ON", "🎯", 170, function()
	if lockOnCooldown then return end
	lockOnCooldown = true
	
	-- Find nearest player
	local nearestPlayer = nil
	local shortestDistance = math.huge
	
	for _, otherPlayer in pairs(game.Players:GetPlayers()) do
		if otherPlayer ~= player and otherPlayer.Character then
			local otherRoot = otherPlayer.Character:FindFirstChild("HumanoidRootPart")
			if otherRoot then
				local distance = (otherRoot.Position - humanoidRootPart.Position).Magnitude
				if distance < shortestDistance then
					shortestDistance = distance
					nearestPlayer = otherPlayer
				end
			end
		end
	end
	
	if nearestPlayer and nearestPlayer.Character then
		local targetRoot = nearestPlayer.Character:FindFirstChild("HumanoidRootPart")
		if targetRoot then
			-- Fly quickly towards them
			local targetPos = targetRoot.Position - (targetRoot.CFrame.LookVector * 3) -- Behind them
			humanoidRootPart.CFrame = CFrame.new(targetPos, targetRoot.Position)
			
			-- Effect
			local effect = Instance.new("Part")
			effect.Shape = Enum.PartType.Ball
			effect.Material = Enum.Material.Neon
			effect.Color = Color3.fromRGB(255, 100, 100)
			effect.Size = Vector3.new(3, 3, 3)
			effect.Anchored = true
			effect.CanCollide = false
			effect.CFrame = CFrame.new(humanoidRootPart.Position)
			effect.Parent = workspace
			
			game:GetService("TweenService"):Create(effect, TweenInfo.new(0.5), {
				Transparency = 1,
				Size = Vector3.new(8, 8, 8)
			}):Play()
			
			game:GetService("Debris"):AddItem(effect, 0.5)
		end
	end
	
	wait(3)
	lockOnCooldown = false
end)

